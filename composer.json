{
  "name": "nogagermainio/noga-se",
  "description": "Fast, fluent and immutable SQL Query Builder for PHP 8.1+ with secure parameter binding and advanced query features.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/nogagermainio/Noga_SE",

  "authors": [
    {
      "name": "nogagermainio",
      "email": "contact@nogagermainio.dev"
    }
  ],

  "require": {
    "php": ">=8.1"
  },

  "autoload": {
    "psr-4": {
      "Noga\\": "src/"
    },
    "files": [
      "src/helpers/helpers.php"
    ]
  },

  "autoload-dev": {
    "psr-4": {
      "Noga\\Tests\\": "test/"
    }
  },

  "minimum-stability": "stable",
  "prefer-stable": true,

  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },

  "scripts": {
    "test": "phpunit",
    "dump": "composer dump-autoload -o"
  },

  "require-dev": {
    "phpunit/phpunit": "^13.2.2"
  }
}
