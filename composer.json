{
  "name": "nogagermainio/noga-se",
  "description": "Fast, fluent and immutable SQL Query Builder for PHP 8.1+",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "Noga\\": "src/",
      "Test\\":"test/"
    },
    "files":[
     "src/helpers/helpers.php"
    ]
  },
  "authors": [
    {
      "name": "ZAFININGELY NOGA Germainio",
      "email": "nogagerma122@gmail.com"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
